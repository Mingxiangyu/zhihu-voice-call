# 火山引擎 API 凭证（必填）
# App ID: 火山引擎控制台 -> 语音技术 -> 应用管理
VOLC_APP_ID=your_app_id_here
# App Key: 火山引擎控制台 -> 应用详情页
VOLC_APP_KEY=your_volc_app_key_here
# Access Key: 火山引擎控制台 -> IAM -> 密钥管理
VOLC_ACCESS_KEY=your_access_key_here

# 服务端口
PORT=3000

# 模型版本 (1.2.1.1 = O2.0, 2.2.0.0 = SC2.0)
MODEL=1.2.1.1

# TTS 音色 (留空使用模型默认)
TTS_VOICE_TYPE=

# ---- 知乎 OpenAPI / OAuth ----
# 知乎开放平台 https://open.zhihu.com 注册应用获取
ZHIHU_APP_ID=your_zhihu_app_id_here
ZHIHU_APP_KEY=your_zhihu_app_key_here
# OAuth 回调地址，需与知乎控制台「应用回调地址」完全一致
ZHIHU_REDIRECT_URI=http://localhost:4001/oauth/callback
ZHIHU_AUTHORIZE_URL=https://openapi.zhihu.com/authorize
ZHIHU_API_BASE=https://openapi.zhihu.com

# AI 主动开口模式：say_hello | system_role
ZHIHU_OPENING_MODE=say_hello

# ---- 会话 / Cookie ----
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=86400
